{
  "name": "minha-gestao-financeira",
  "version": "2.0.0",
  "private": true,
  "description": "Aplicação multi-tenant para gestão financeira pessoal com autenticação OAuth 2.0",
  "author": "Matheus Meigre",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "Remove-Item -Recurse -Force .next, node_modules -ErrorAction SilentlyContinue",
    "setup": "npm install && echo '✅ Dependências instaladas! Agora configure o .env.local (veja QUICKSTART.md)'",
    "check-auth": "echo '🔍 Verificando configuração de autenticação...' && node -e \"console.log(process.env.NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY ? '✅ Chave pública configurada' : '❌ Configure NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY em .env.local')\" && node -e \"console.log(process.env.CLERK_SECRET_KEY ? '✅ Chave secreta configurada' : '❌ Configure CLERK_SECRET_KEY em .env.local')\""
  },
  "dependencies": {
    "@clerk/localizations": "^4.13.6",
    "@clerk/nextjs": "^7.5.22",
    "@hookform/resolvers": "^5.4.0",
    "@radix-ui/react-accordion": "1.2.2",
